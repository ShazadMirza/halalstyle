# Required — Claude API (get from console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-api03-...

# Optional — ConvertKit email capture (get from app.convertkit.com)
CONVERTKIT_API_KEY=
# Quiz / multi-field subscribe (Style Quiz + email gate)
CONVERTKIT_FORM_ID=
# Homepage newsletter + Excellence Guide (POST /api/newsletter). Falls back to CONVERTKIT_FORM_ID if unset.
CONVERTKIT_NEWSLETTER_FORM_ID=

# Optional — Partner applications (/partners). Create table `partners` with columns:
# name (text), social_handle (text, nullable), email (text), created_at (timestamptz default now()).
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
