# Required — Claude API (get from console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-api03-...

# Optional — ConvertKit email capture (get from app.convertkit.com)
CONVERTKIT_API_KEY=
# Quiz / multi-field subscribe (Style Quiz + email gate)
CONVERTKIT_FORM_ID=
# Homepage newsletter + Excellence Guide (POST /api/newsletter). Falls back to CONVERTKIT_FORM_ID if unset.
CONVERTKIT_NEWSLETTER_FORM_ID=
# Tag applied after every successful /api/newsletter subscribe — MUST match a tag in ConvertKit that starts
# a Visual Automation: "Tag is added" → send broadcast/sequence "Your 2026 Excellence Guide" (include PDF URL).
# Default tag name in code is "Excellence Guide 2026" if unset.
# Segment tags (create in CK; used only inside Visual Automations — not sent by this API):
#   "Engaged Week 1" / "Needs Re-engagement" — see lib/excellence-guide-constants.ts (post–Email 2 split).
CONVERTKIT_EXCELLENCE_GUIDE_TAG=
# Alias for the same (either may be set)
CONVERTKIT_EXCELLENCE_AUTOMATION_TAG=

# Optional — Partner applications (/partners). Create table `partners` with columns:
# name (text), social_handle (text, nullable), email (text), created_at (timestamptz default now()).
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional — Resend notifies partner inbox (defaults to partners@halalstyles55.com)
RESEND_API_KEY=
PARTNERS_NOTIFY_EMAIL=
